# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── MySQL DB (agents_db) ───────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=agents_db

# ── ERPNext MySQL DB ───────────────────────────────────────────────────────────
ERPNEXT_MYSQL_HOST=erpnext_db_host
ERPNEXT_MYSQL_PORT=3306
ERPNEXT_MYSQL_USER=erpnext_user
ERPNEXT_MYSQL_PASSWORD=erpnext_password
ERPNEXT_MYSQL_DATABASE=site1_local

# ── Redis (swarm pub/sub) ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── ERPNext Redis ──────────────────────────────────────────────────────────────
ERPNEXT_REDIS_HOST=erpnext_redis_host
ERPNEXT_REDIS_PORT=13000
ERPNEXT_REDIS_DB=0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=/home/agents/data/chroma

# ── API Server Auth ────────────────────────────────────────────────────────────
# Strong random secret for JWT signing — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-strong-random-secret

# Comma-separated valid CORS origins
API_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# JSON map of email → password for local login (alternative to Google OAuth)
# Example: {"admin@truematrix.io": "SecurePass123"}
VALID_USERS_JSON={}

# ── Google OAuth (for /google-login endpoint) ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── Google Search Console / SEO Agent ─────────────────────────────────────────
GSC_SERVICE_ACCOUNT_FILE=/path/to/agents/seo_agent/credentials/gsc_service_account.json
GSC_OAUTH_FILE=/root/.cache/google-vscode-extension/auth/application_default_credentials.json
GSC_FORCE_SERVICE_ACCOUNT=true
GSC_SITE_URLS=sc-domain:indogenmed.org,https://indogenmed.org/
GSC_DAYS_HISTORY=28
GSC_ROW_LIMIT=5000

# ── Google Analytics 4 ────────────────────────────────────────────────────────
GA4_PROPERTY_ID=your_ga4_property_id
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── SEO Agent API ─────────────────────────────────────────────────────────────
SEO_API_PORT=9001
SEO_API_SECRET=your_seo_api_secret_here

# ── SEO Thresholds ────────────────────────────────────────────────────────────
CTR_DROP_THRESHOLD=0.3
POSITION_DROP_THRESHOLD=5.0
MIN_IMPRESSIONS=50
LOW_CTR_IMPRESSION_MIN=100
LOW_CTR_RATE_MAX=0.02

# ── WooCommerce / Integration Agent ───────────────────────────────────────────
WC_URL=https://your-woocommerce-store.com
WC_INDOGENMED_CK=your_woocommerce_consumer_key
WC_INDOGENMED_CS=your_woocommerce_consumer_secret

# ── Server Agent ──────────────────────────────────────────────────────────────
MCP_CONFIG_PATH=/home/mcp
