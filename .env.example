# -----------------------------
# LLM CLI Fallback (recommended)
# -----------------------------
# Enable fallback to local CLIs when API providers (Anthropic/OpenAI/Gemini API) fail.
LLM_CLI_FALLBACK_ENABLED=true
LLM_CLI_TIMEOUT_SECONDS=120

# Preferred execution order for CLI fallbacks.
# Keep only CLIs that are actually installed/configured on your host.
LLM_CLI_ORDER=codex,claude,copilot

# JSON map of command templates. Available placeholders:
# - {full_prompt}: merged system + user prompt (shell-escaped)
# - {prompt}: user prompt only (shell-escaped)
# - {system_prompt}: system prompt only (shell-escaped)
#
# Verified command styles for this environment:
# - codex:   codex exec <prompt>
# - claude:  claude --print <prompt>
# - copilot: copilot --prompt <prompt>
# - gemini:  installed, but non-interactive flag differs by build; keep optional.
#
# IMPORTANT:
# 1) Keep this as valid JSON.
# 2) Wrap the full JSON string in single quotes in .env.
LLM_CLI_COMMANDS_JSON='{"codex":"/root/.nvm/versions/node/v24.14.0/bin/codex exec --skip-git-repo-check --sandbox workspace-write --full-auto {full_prompt}","claude":"/root/.local/bin/claude --print {full_prompt}","copilot":"/root/.nvm/versions/node/v24.14.0/bin/copilot --prompt {full_prompt}"}'

# Optional Gemini entry (uncomment only after confirming your installed gemini CLI flags):
# LLM_CLI_ORDER=codex,claude,copilot,gemini
# LLM_CLI_COMMANDS_JSON='{"codex":"codex exec --skip-git-repo-check --sandbox workspace-write --full-auto {full_prompt}","claude":"claude --print {full_prompt}","copilot":"copilot --prompt {full_prompt}","gemini":"gemini --prompt {full_prompt}"}'

# Google login allowlist
GOOGLE_ALLOWED_DOMAINS=truematrix.io
GOOGLE_ALLOWED_EMAILS=surya@truematrix.io
